{
  "name": "cadastro-ci",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "dev:all": "concurrently -n api,web -c green,cyan \"npm run server\" \"npm run dev\"",
    "build": "npx vite build",
    "build:deploy": "node scripts/rm-node-modules.mjs && npm ci && npm run build",
    "preview": "vite preview",
    "server": "npx tsx server/index.ts",
    "start": "cross-env NODE_ENV=production SERVE_STATIC=1 npx tsx server/index.ts",
    "db:seed": "tsx scripts/seed-sqlite.ts",
    "db:import-patients": "tsx scripts/import-patients.ts",
    "db:import-xls": "tsx scripts/import-patients-xls.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "audit:extract": "python scripts/extract-surgical-pdfs.py",
    "audit:report": "python scripts/cij_consolidated_report.py"
  },
