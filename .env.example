# --- Frontend (Vite; público no bundle) ---
# Client ID OAuth 2.0 (tipo "Aplicação Web") no Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=

# Opcional: URL absoluta da API se o front estiver noutro domínio (ex.: Vercel estático + API no Render).
# VITE_API_URL=https://api.seudominio.com
#
# OAuth local (Vite): no Google Cloud, o redirect tem de bater com o URL do browser, ex.:
#   http://localhost:5173/api/oauth/google/callback
#   http://localhost:5174/api/oauth/google/callback  (se a porta 5173 estiver ocupada)

# --- Servidor (Node / Express; NUNCA expor GOOGLE_CLIENT_SECRET ao cliente) ---
# Porta local do Express (predefinido 3000). Se aparecer EADDRINUSE, use 3001 e reinicie Vite.
# PORT=3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Segredo para assinar o cookie de sessão (≥32 caracteres em produção).
SESSION_SECRET=

# Opcional: caminho da base SQLite (predefinido: ./data/cij.db)
# SQLITE_DB_PATH=./data/cij.db

# Braintrust (opcional)
# BRAINTRUST_API_KEY=
# BRAINTRUST_PROJECT_ID=
